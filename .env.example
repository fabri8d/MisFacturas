# ============================================================
# MisFacturas v2 — Variables de entorno
# Copiá este archivo a .env y completá los valores
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Requerido. Creá un proyecto en supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role key — acceso completo, SOLO para el backend
SUPABASE_SERVICE_KEY=eyJ...
# anon key — para el frontend y para verificar JWTs
SUPABASE_ANON_KEY=eyJ...
# JWT secret — Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# ── Groq AI ─────────────────────────────────────────────────
# Requerido. Obtené tu clave en console.groq.com (tier gratuito disponible)
GROQ_API_KEY=

# ── Telegram ─────────────────────────────────────────────────
# Opcional. Token del bot global del servidor (para notificaciones del sistema).
# Los usuarios configuran su propio telegram_chat_id en su perfil de la app.
# 1. Buscá @BotFather en Telegram → /newbot → copiá el token
TELEGRAM_BOT_TOKEN=
# Hora (0-23) a la que se envían las notificaciones diarias (zona horaria Argentina)
NOTIFY_HOUR=9

# ── Google Drive ─────────────────────────────────────────────
# Opcional. La integración con Drive queda deshabilitada si no está configurada.
# Creá las credenciales en console.cloud.google.com → APIs → OAuth 2.0 Client ID
# Usá la misma app para todos los usuarios (una sola app, tokens por usuario en Supabase)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI de redirección OAuth — debe coincidir exactamente con la configurada en Google Cloud
# También agregar https://[proyecto].supabase.co/auth/v1/callback en Google Cloud
GOOGLE_REDIRECT_URI=https://misfacturas-fabriziobiondi.duckdns.org/api/drive/oauth/callback

# ── App ──────────────────────────────────────────────────────
# URL pública de la app (usada por Drive para recibir webhooks — debe ser HTTPS)
APP_BASE_URL=https://misfacturas-fabriziobiondi.duckdns.org
# URL del frontend para CORS (en desarrollo: http://localhost:5173)
FRONTEND_URL=https://misfacturas-fabriziobiondi.duckdns.org

# Zona horaria del contenedor
TZ=America/Argentina/Buenos_Aires

# ── Frontend (prefijo VITE_ requerido por Vite) ──────────────
# En producción /api es ruteado por Nginx al backend; en dev el proxy de Vite hace lo mismo
VITE_API_BASE_URL=/api
# Supabase para el cliente JS (anon key — segura para exponer al frontend)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
